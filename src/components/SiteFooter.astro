---
const baseUrl = import.meta.env.BASE_URL
---

<footer class="site-footer">
  <nav aria-label="Footer">
    <ul class="site-footer__list">
      <li><a href={`${baseUrl}sources/`}>Sources</a></li>
      <li><a href={`${baseUrl}events/`}>Events</a></li>
      <li><a href="#">Suggest a source</a></li>
    </ul>
  </nav>
</footer>

<style>
  .site-footer {
    max-width: 720px;
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid #d8d3c7;
    font-size: 0.95rem;
  }

  .site-footer__list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.25rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .site-footer a {
    color: #1d70b8;
    text-decoration-thickness: 0.06em;
    text-underline-offset: 0.16em;
  }

  .site-footer a:hover {
    color: #003078;
    text-decoration-thickness: 0.12em;
  }

  .site-footer a:focus {
    outline: 3px solid #ffdd00;
    outline-offset: 2px;
    background: #ffdd00;
    color: #000000;
  }
</style>
