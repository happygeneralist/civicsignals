---
const { current = 'updates' } = Astro.props
const baseUrl = import.meta.env.BASE_URL
---

<nav class="service-nav" aria-label="Primary navigation">
  <ul class="service-nav__list">
    <li>
      <a class="service-nav__link" href={baseUrl} aria-current={current === 'updates' ? 'page' : undefined}>Latest updates</a>
    </li>
    <li>
      <a class="service-nav__link" href={`${baseUrl}sources/`} aria-current={current === 'sources' ? 'page' : undefined}>Sources</a>
    </li>
    <li>
      <a class="service-nav__link" href={`${baseUrl}events/`} aria-current={current === 'events' ? 'page' : undefined}>Events</a>
    </li>
  </ul>
</nav>
