---
import '../styles/global.css'
import items from '../data/items.json'
import status from '../data/status.json'

const ITEMS_PER_PAGE = 100

const totalItems = items.length
const totalPages = Math.ceil(totalItems / ITEMS_PER_PAGE)
const pageItems = items.slice(0, ITEMS_PER_PAGE)

const startItem = totalItems === 0 ? 0 : 1
const endItem = Math.min(ITEMS_PER_PAGE, totalItems)

const refreshedAt = status.checkedAt
  ? new Date(status.checkedAt).toLocaleString('en-GB', {
      day: '2-digit',
      month: 'short',
      year: 'numeric',
      hour: '2-digit',
      minute: '2-digit'
    })
  : null
---

<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Civic Signals</title>
  </head>

  <body>
    <main class="page">
      <header class="masthead">
        <p class="site-label">Civic Signals</p>

        <h1>Digital government news</h1>

        <p class="lede">
          Useful updates from across digital government.
        </p>
      </header>

      <section aria-labelledby="latest-updates">
        <div class="section-header">
          <div class="section-title">
            <h2 id="latest-updates">Latest updates</h2>

            {refreshedAt && (
              <p class="refresh-time">
                Refreshed {refreshedAt}
              </p>
            )}
          </div>
  {totalItems > 0 && (
    <p class="feed-count">
      Showing {startItem} to {endItem} of {totalItems} items
    </p>
  )}
        </div>



        {totalItems === 0 ? (
          <p>No feed items have been imported yet.</p>
        ) : (
          <ol class="feed" aria-label="Latest digital government updates">
            {pageItems.map((item, index) => (
              <li class="feed-item">
                <div class="feed-index" aria-hidden="true">
                  {index + 1}.
                </div>

                <div class="feed-content">
                  <h3>
                    <a href={item.url}>{item.title}</a>
                  </h3>

                  <p class="meta">
                    <span>{item.sourceName}</span>
                    {item.publishedAt && (
                      <>
                        <span aria-hidden="true"> · </span>
                        <time datetime={item.publishedAt}>
                          {new Date(item.publishedAt).toLocaleDateString('en-GB', {
                            day: '2-digit',
                            month: 'short',
                            year: 'numeric'
                          })}
                        </time>
                      </>
                    )}
                  </p>
                </div>
              </li>
            ))}
          </ol>
        )}

        {totalPages > 1 && (
          <nav class="pagination" aria-label="Pagination">
            <a class="pagination-next" href={`${import.meta.env.BASE_URL}page/2/`}>
              Older updates
            </a>
          </nav>
        )}
      </section>

      <p class="govuk-body">
        <a class="govuk-link" href={`${import.meta.env.BASE_URL}sources/`}>
          View sources
        </a>
      </p>
    </main>
  </body>
</html>
